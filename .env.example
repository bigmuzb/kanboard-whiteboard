# Kanboard Whiteboard — Environment Configuration
# Copy to .env and edit before running: cp .env.example .env

# Brand name displayed in the UI (e.g. "Site Board", "Ops Whiteboard")
BRAND_NAME=Kanboard Whiteboard

# Kanboard API credentials
KANBOARD_USER=jsonrpc
KANBOARD_KEY=changeme

# Port exposed on the host
PORT=3000

# Admin secret (auto-generated if not set)
# ADMIN_SECRET=

# Optional analytics injection. Leave blank unless you operate the hosted instance.
# UMAMI_SCRIPT_URL=https://analytics.example.com/script.js
# UMAMI_WEBSITE_ID=
# UMAMI_DOMAINS=your-demo.example.com
